{
  "name": "expo-app",
  "slug": "otto-assistant",
  "version": "1.0.0",
  "orientation": "portrait",
  "icon": "./assets/icon.png",
  "userInterfaceStyle": "dark",
  "splash": {
    "image": "./assets/splash.png",
    "resizeMode": "contain",
    "backgroundColor": "#0F172A"
  },
  "assetBundlePatterns": ["**/*"],
  "ios": {
    "supportsTabletMode": true,
    "infoPlist": {
      "NSMicrophoneUsageDescription": "OTTO needs microphone access to hear you",
      "NSCameraUsageDescription": "OTTO needs camera access for vision features"
    }
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#0F172A"
    },
    "permissions": [
      "android.permission.RECORD_AUDIO",
      "android.permission.CAMERA",
      "android.permission.INTERNET"
    ]
  },
  "web": {
    "favicon": "./assets/favicon.png"
  },
  "plugins": [
    "expo-camera",
    "expo-av",
    "expo-permissions",
    "expo-notifications"
  ]
}
